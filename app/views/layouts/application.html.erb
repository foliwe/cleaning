<!DOCTYPE html>
<html>
  <head>
    <title>CleaningApp</title>
    <%= csrf_meta_tags %>

    <%= stylesheet_link_tag    'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>


  </head>

  <body>
    <div class=" w3-blue-grey">

      <div class="w3-bar w3-light-grey">
      <span class="w3-bar-item ">APP NAME</span>
       <a href="#" class="w3-bar-item w3-button">Link 1</a>
        <% if user_signed_in?%>
        <div class="w3-dropdown-hover">
          <button class="w3-button"><%= current_user.email%></button>
          <div class="w3-dropdown-content w3-bar-block w3-card-4">
            <a href="#" class="w3-bar-item w3-button">Link 1</a>
            <a href="#" class="w3-bar-item w3-button">Link 2</a>
            <a href="#" class="w3-bar-item w3-button">Link 3</a>
          </div>
        </div>
         <div class=""><%=link_to 'Add Member', new_member_path, class:"w3-bar-item w3-button"%></div>
         <div class=""><%=link_to 'Logout', destroy_user_session_path,method: :delete, class:"w3-bar-item w3-button"%></div>
        <%else%>
        <div class=""><%=link_to 'Login', new_user_session_path, class:"w3-bar-item w3-button"%></div>
        <%end%>
    </div>

  </div>

  <div class="">
  <% flash.each do |key, value| %>
    <div class="alert alert-<%= key %>">
      <%= value %>
    </div>
  <% end %>
</div>
    <%= yield %>
  </body>
</html>
